# ===== Master server =====

# Secret для подписи session cookie. Сгенерируй: openssl rand -hex 32
SESSION_SECRET=CHANGE_ME_RUN_openssl_rand_hex_32

# Postgres connection
DATABASE_URL=postgresql://pc:pcpwd@localhost:5432/pocket_claude

# Порт, на котором слушает master (HTTP + WS)
PORT=3100

# Публичный URL мастера (для connect.sh)
# Продакшн: https://claude.mydomain.com
# Локально: http://localhost:3100
PUBLIC_URL=http://localhost:3100

# Single-user mode (для себя): email и пароль админа создадутся при setup
SINGLE_USER_MODE=true
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Ключ для шифрования интеграционных токенов (github etc) — AES-256-GCM
INTEGRATION_KEY=CHANGE_ME_RUN_openssl_rand_hex_32
